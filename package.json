{
	"name": "easy-recall",
	"version": "1.2.22",
	"description": "极简 Obsidian 间隔重复插件",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"version": "node scripts/version-bump.mjs && git add manifest.json package.json",
		"prerelease": "node scripts/prerelease.mjs",
		"release:prerelease": "node scripts/prerelease.mjs --publish",
		"release:stable": "node scripts/release.mjs --publish",
		"changelog:release": "node scripts/generate-release-notes.mjs",
		"verify": "npm test -- --runInBand && npm run build",
		"verify:release": "node scripts/verify-release.mjs",
		"prepublish": "npm run build && npm test && npm run check-dist",
		"check-dist": "node scripts/check-dist.mjs"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"spaced-repetition"
	],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"esbuild": "0.17.3",
		"jest": "^30.2.0",
		"obsidian": "latest",
		"ts-jest": "^29.4.6",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	}
}
